<!-- Scheduled Message Modal -->
<div id="scheduled-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4">
  <div class="modal-backdrop absolute inset-0" onclick="closeScheduledModal()"></div>
  <div class="modal-box relative bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-bold text-gray-900">New Scheduled Message</h2>
      <button onclick="closeScheduledModal()" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg"><i class="fas fa-times"></i></button>
    </div>
    <div class="p-6 space-y-4">
      <div>
        <label class="text-xs font-semibold text-gray-500 block mb-1">Recipient Phone *</label>
        <div class="flex gap-2">
          <input id="sched-phone" class="field flex-grow" placeholder="e.g. 22890123456">
          <button type="button" onclick="openScheduledContactPicker()" class="text-xs bg-indigo-50 hover:bg-indigo-100 text-indigo-700 px-3 py-2 rounded-xl font-semibold flex-shrink-0"><i class="fas fa-address-book"></i></button>
        </div>
        <div id="sched-contact-name" class="text-xs text-green-600 mt-1 hidden"></div>
      </div>
      <div><label class="text-xs font-semibold text-gray-500 block mb-1">Message *</label><textarea id="sched-message" rows="4" class="field resize-none" placeholder="Write your message…"></textarea></div>
      <div><label class="text-xs font-semibold text-gray-500 block mb-1">Send At *</label><input type="datetime-local" id="sched-at" class="field"></div>
    </div>
    <div class="px-6 py-3.5 border-t border-gray-100 bg-gray-50 flex justify-end gap-2">
      <button onclick="closeScheduledModal()" class="text-sm text-gray-600 px-4 py-2 rounded-xl border border-gray-200 hover:bg-white font-medium">Cancel</button>
      <button onclick="saveScheduledMessage()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2 rounded-xl text-sm font-semibold"><i class="fas fa-clock text-xs mr-1.5"></i>Schedule</button>
    </div>
  </div>
</div>

