<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WhatsBot — Scan QR Code</title>
  <link rel="icon" href="/public/favicon.png">
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    * { box-sizing: border-box; }
    body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background: #0f172a; color: #f1f5f9; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24px; }
    .bg-mesh {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(37,211,102,0.12) 0%, transparent 60%),
                  radial-gradient(ellipse 50% 50% at 80% 90%, rgba(79,70,229,0.1) 0%, transparent 60%);
    }
    .logo-icon {
      width: 52px; height: 52px; border-radius: 16px;
      background: linear-gradient(135deg, #25d366, #075e54);
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 8px 24px rgba(37,211,102,0.3);
      margin: 0 auto 16px;
    }
    .qr-wrapper {
      background: white;
      border-radius: 20px;
      padding: 16px;
      box-shadow: 0 0 0 1px rgba(255,255,255,0.06), 0 24px 64px rgba(0,0,0,0.5);
      display: inline-block;
      position: relative;
    }
    .qr-wrapper img { border-radius: 8px; display: block; }
    .qr-corner {
      position: absolute; width: 20px; height: 20px;
      border-color: #25d366; border-style: solid;
    }
    .qr-corner.tl { top: -2px; left: -2px; border-width: 3px 0 0 3px; border-radius: 4px 0 0 0; }
    .qr-corner.tr { top: -2px; right: -2px; border-width: 3px 3px 0 0; border-radius: 0 4px 0 0; }
    .qr-corner.bl { bottom: -2px; left: -2px; border-width: 0 0 3px 3px; border-radius: 0 0 0 4px; }
    .qr-corner.br { bottom: -2px; right: -2px; border-width: 0 3px 3px 0; border-radius: 0 0 4px 0; }
    .loader-ring {
      width: 260px; height: 260px;
      border-radius: 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 16px;
    }
    .spin { animation: spin 1s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .status-pill {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 8px 18px; border-radius: 999px; font-size: 0.82rem; font-weight: 600;
      transition: all 0.3s;
    }
    .status-pill.waiting { background: rgba(245,158,11,0.15); color: #fbbf24; border: 1px solid rgba(245,158,11,0.2); }
    .status-pill.success { background: rgba(34,197,94,0.15); color: #4ade80; border: 1px solid rgba(34,197,94,0.2); }
    .status-pill.error   { background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(239,68,68,0.2); }
    .step {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .step:last-child { border-bottom: none; }
    .step-num {
      width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0;
      background: rgba(37,211,102,0.15); border: 1px solid rgba(37,211,102,0.25);
      color: #4ade80; font-size: 0.72rem; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
    }
  </style>
</head>
<body>
<div class="bg-mesh"></div>

<div style="position:relative;z-index:1;width:100%;max-width:480px;">

  <!-- Header -->
  <div class="text-center mb-8">
    <div class="logo-icon">
      <i class="fab fa-whatsapp text-white text-2xl"></i>
    </div>
    <h1 class="text-3xl font-bold text-white mb-2" style="letter-spacing:-0.02em">Scan to Connect</h1>
    <p style="color:rgba(255,255,255,0.4);font-size:0.88rem;">Link your WhatsApp account to WhatsBot</p>
  </div>

  <!-- QR / Loader -->
  <div class="flex justify-center mb-6">
    <div id="qr-area">
      <% if (qrCodeData) { %>
        <div class="qr-wrapper">
          <div class="qr-corner tl"></div><div class="qr-corner tr"></div>
          <div class="qr-corner bl"></div><div class="qr-corner br"></div>
          <img
            src="https://api.qrserver.com/v1/create-qr-code/?data=<%= encodeURIComponent(qrCodeData) %>&size=260x260&margin=4"
            alt="WhatsApp QR Code" width="260" height="260">
        </div>
      <% } else { %>
        <div class="loader-ring">
          <i class="fas fa-circle-notch spin text-green-400 text-3xl"></i>
          <span style="color:rgba(255,255,255,0.4);font-size:0.82rem;">Generating QR code…</span>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Status pill -->
  <div class="flex justify-center mb-6">
    <div id="status-pill" class="status-pill waiting">
      <i id="status-icon" class="fas fa-hourglass-half"></i>
      <span id="status-text">Waiting for scan…</span>
    </div>
  </div>

  <!-- Instructions -->
  <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:20px 24px;margin-bottom:24px;">
    <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:rgba(255,255,255,0.3)">How to scan</p>
    <div class="step">
      <div class="step-num">1</div>
      <div><p class="text-sm text-white font-medium">Open WhatsApp on your phone</p><p class="text-xs mt-0.5" style="color:rgba(255,255,255,0.4)">Make sure you are signed in</p></div>
    </div>
    <div class="step">
      <div class="step-num">2</div>
      <div><p class="text-sm text-white font-medium">Go to Settings → Linked Devices</p><p class="text-xs mt-0.5" style="color:rgba(255,255,255,0.4)">Tap the three-dot menu (Android) or Settings tab (iOS)</p></div>
    </div>
    <div class="step">
      <div class="step-num">3</div>
      <div><p class="text-sm text-white font-medium">Tap "Link a Device" and scan this QR</p><p class="text-xs mt-0.5" style="color:rgba(255,255,255,0.4)">Point your camera at the code above</p></div>
    </div>
  </div>

  <p class="text-center text-xs" style="color:rgba(255,255,255,0.2)">QR code refreshes automatically · WhatsBot</p>
</div>

<script>
  let lastQrCode = '';

  function setStatus(type, text) {
    const pill = document.getElementById('status-pill');
    const icon = document.getElementById('status-icon');
    const span = document.getElementById('status-text');
    pill.className = 'status-pill ' + type;
    span.textContent = text;
    if (type === 'waiting') icon.className = 'fas fa-hourglass-half';
    else if (type === 'success') icon.className = 'fas fa-check-circle';
    else icon.className = 'fas fa-exclamation-circle';
  }

  function checkStatus() {
    fetch('/qr-status')
      .then(r => r.json())
      .then(data => {
        if (data.qrCodeData && data.qrCodeData !== lastQrCode) {
          lastQrCode = data.qrCodeData;
          location.reload();
        }
        if (data.qrScanned) {
          setStatus('success', 'Authenticated! Redirecting…');
          setTimeout(() => { window.location.href = '/'; }, 1200);
        } else if (data.qrCodeData) {
          setStatus('waiting', 'Waiting for scan…');
        }
      })
      .catch(() => setStatus('error', 'Connection error — retrying…'));
  }

  checkStatus();
  setInterval(checkStatus, 3000);
</script>
</body>
</html>
