              <button type="button" onclick="selectEnglishSpeakers()" class="text-xs bg-green-50 hover:bg-green-100 text-green-700 px-2.5 py-1 rounded-lg font-semibold">🇬🇧 English</button>
              <button type="button" onclick="selectFrenchSpeakers()" class="text-xs bg-purple-50 hover:bg-purple-100 text-purple-700 px-2.5 py-1 rounded-lg font-semibold">🇫🇷 French</button>
              <button type="button" onclick="deselectAllContacts()" class="text-xs bg-red-50 hover:bg-red-100 text-red-700 px-2.5 py-1 rounded-lg font-semibold ml-auto">Clear</button>
