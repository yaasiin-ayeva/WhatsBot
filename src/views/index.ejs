<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WhatsBot — Status</title>
  <link rel="icon" href="/public/favicon.png">
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    * { box-sizing: border-box; }
    body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background: #0f172a; color: #f1f5f9; min-height: 100vh; }
    .bg-mesh {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background: radial-gradient(ellipse 70% 50% at 10% 10%, rgba(37,211,102,0.1) 0%, transparent 60%),
                  radial-gradient(ellipse 60% 50% at 90% 90%, rgba(79,70,229,0.12) 0%, transparent 60%);
    }
    .navbar {
      position: relative; z-index: 10;
      background: rgba(255,255,255,0.03);
      border-bottom: 1px solid rgba(255,255,255,0.07);
      backdrop-filter: blur(12px);
      padding: 14px 32px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo-pill {
      display: flex; align-items: center; gap: 10px;
    }
    .logo-icon {
      width: 36px; height: 36px; border-radius: 10px;
      background: linear-gradient(135deg, #25d366, #075e54);
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 12px rgba(37,211,102,0.3);
      flex-shrink: 0;
    }
    .card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 18px;
      backdrop-filter: blur(10px);
      padding: 20px;
    }
    .stat-row {
      display: flex; align-items: center; gap: 12px;
      padding: 13px 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .stat-row:last-child { border-bottom: none; padding-bottom: 0; }
    .stat-row:first-child { padding-top: 0; }
    .stat-icon { width: 32px; height: 32px; border-radius: 9px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.8rem; }
    .stat-label { font-size: 0.78rem; color: rgba(255,255,255,0.4); font-weight: 500; }
    .stat-value { font-size: 0.87rem; color: #f1f5f9; font-weight: 600; margin-top: 1px; font-family: 'Menlo', monospace; }
    .pulse-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .pulse-dot.green  { background: #22c55e; box-shadow: 0 0 0 0 rgba(34,197,94,0.5); animation: pulse-green 2s infinite; }
    .pulse-dot.red    { background: #ef4444; }
    .pulse-dot.yellow { background: #f59e0b; box-shadow: 0 0 0 0 rgba(245,158,11,0.5); animation: pulse-yellow 2s infinite; }
    @keyframes pulse-green  { 0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,0.4)} 50%{box-shadow:0 0 0 8px rgba(34,197,94,0)} }
    @keyframes pulse-yellow { 0%,100%{box-shadow:0 0 0 0 rgba(245,158,11,0.4)} 50%{box-shadow:0 0 0 8px rgba(245,158,11,0)} }
    .status-badge {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 5px 12px; border-radius: 999px; font-size: 0.78rem; font-weight: 600;
    }
    .status-badge.healthy  { background: rgba(34,197,94,0.15); color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
    .status-badge.unhealthy{ background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(239,68,68,0.25); }
    .status-badge.scanning { background: rgba(245,158,11,0.15); color: #fbbf24; border: 1px solid rgba(245,158,11,0.25); }
    .admin-btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(79,70,229,0.15); border: 1px solid rgba(79,70,229,0.3);
      color: #a5b4fc; padding: 8px 16px; border-radius: 10px; font-size: 0.82rem; font-weight: 600;
      text-decoration: none; transition: background 0.15s, border-color 0.15s;
    }
    .admin-btn:hover { background: rgba(79,70,229,0.25); border-color: rgba(79,70,229,0.5); color: #c7d2fe; }
    .uptime-bar { height: 3px; background: rgba(255,255,255,0.07); border-radius: 999px; overflow: hidden; margin-top: 6px; }
    .uptime-fill { height: 100%; background: linear-gradient(90deg, #25d366, #4ade80); border-radius: 999px; transition: width 0.5s; }
  </style>
</head>
<body>

<div class="bg-mesh"></div>

<!-- Navbar -->
<nav class="navbar">
  <div class="logo-pill">
    <div class="logo-icon"><i class="fab fa-whatsapp text-white"></i></div>
    <div>
      <div class="font-bold text-white text-sm">WhatsBot</div>
      <div class="text-xs" style="color:rgba(255,255,255,0.35)">Automated WhatsApp Bot</div>
    </div>
  </div>
  <a href="/admin" class="admin-btn"><i class="fas fa-shield-alt text-xs"></i>Admin Panel</a>
</nav>

<!-- Main -->
<main class="relative z-10 max-w-2xl mx-auto px-4 py-12">

  <!-- Hero -->
  <div class="text-center mb-10">
    <div id="status-badge" class="status-badge scanning inline-flex mb-4">
      <div class="pulse-dot yellow"></div>
      <span id="status-text">Checking…</span>
    </div>
    <h1 class="text-4xl font-bold text-white mb-3" style="letter-spacing:-0.02em">WhatsBot is <span id="hero-word" class="text-green-400">loading</span></h1>
    <p style="color:rgba(255,255,255,0.4); font-size:0.9rem;">Real-time status of your WhatsApp automation bot</p>
  </div>

  <!-- Status Card -->
  <div class="card mb-5">
    <div class="flex items-center justify-between mb-4">
      <span class="text-xs font-semibold uppercase tracking-widest" style="color:rgba(255,255,255,0.35)">Bot Information</span>
      <span id="last-updated" class="text-xs" style="color:rgba(255,255,255,0.25)">Updating…</span>
    </div>

    <div class="stat-row">
      <div class="stat-icon" style="background:rgba(34,197,94,0.15)"><i class="fas fa-circle text-green-400" style="font-size:0.55rem"></i></div>
      <div class="flex-1"><div class="stat-label">App State</div><div class="stat-value" id="val-status">—</div></div>
    </div>
    <div class="stat-row">
      <div class="stat-icon" style="background:rgba(99,102,241,0.15)"><i class="fas fa-qrcode text-indigo-400"></i></div>
      <div class="flex-1"><div class="stat-label">QR Scanned</div><div class="stat-value" id="val-qr">—</div></div>
    </div>
    <div class="stat-row">
      <div class="stat-icon" style="background:rgba(245,158,11,0.15)"><i class="fas fa-phone text-yellow-400"></i></div>
      <div class="flex-1"><div class="stat-label">Bot Contact</div><div class="stat-value" id="val-contact">—</div></div>
    </div>
    <div class="stat-row">
      <div class="stat-icon" style="background:rgba(236,72,153,0.15)"><i class="fas fa-id-badge text-pink-400"></i></div>
      <div class="flex-1"><div class="stat-label">Push Name</div><div class="stat-value" id="val-pushname">—</div></div>
    </div>
    <div class="stat-row">
      <div class="stat-icon" style="background:rgba(20,184,166,0.15)"><i class="fas fa-mobile-alt text-teal-400"></i></div>
      <div class="flex-1"><div class="stat-label">Platform</div><div class="stat-value" id="val-platform">—</div></div>
    </div>
    <div class="stat-row">
      <div class="stat-icon" style="background:rgba(79,70,229,0.15)"><i class="fas fa-clock text-indigo-300"></i></div>
      <div class="flex-1">
        <div class="stat-label">Uptime</div>
        <div class="stat-value" id="val-uptime">—</div>
        <div class="uptime-bar mt-1"><div class="uptime-fill" id="uptime-fill" style="width:0%"></div></div>
      </div>
    </div>
    <div class="stat-row">
      <div class="stat-icon" style="background:rgba(148,163,184,0.1)"><i class="fas fa-code-branch text-gray-400"></i></div>
      <div class="flex-1"><div class="stat-label">Version</div><div class="stat-value" id="val-version">—</div></div>
    </div>
  </div>

  <!-- Footer -->
  <p class="text-center text-xs mt-8" style="color:rgba(255,255,255,0.2)">
    WhatsBot &nbsp;·&nbsp; Auto-refreshes every 3 seconds &nbsp;·&nbsp;
    <a href="https://github.com/yaasiin-ayeva/WhatsBot" target="_blank" class="underline hover:text-white transition-colors">GitHub</a>
  </p>
</main>

<script>
  const $ = id => document.getElementById(id);

  function formatUptime(seconds) {
    if (!seconds) return '—';
    const d = Math.floor(seconds / 86400);
    const h = Math.floor((seconds % 86400) / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = Math.floor(seconds % 60);
    if (d > 0) return `${d}d ${h}h ${m}m`;
    if (h > 0) return `${h}h ${m}m ${s}s`;
    if (m > 0) return `${m}m ${s}s`;
    return `${s}s`;
  }

  function setStatus(status) {
    const badge = $('status-badge');
    const text  = $('status-text');
    const heroWord = $('hero-word');
    badge.className = 'status-badge inline-flex mb-4';
    const dot = badge.querySelector('.pulse-dot');

    if (status === 'healthy') {
      badge.classList.add('healthy');
      dot.className = 'pulse-dot green';
      text.textContent = 'Healthy';
      heroWord.textContent = 'running';
      heroWord.className = 'text-green-400';
    } else if (status === 'scanning') {
      badge.classList.add('scanning');
      dot.className = 'pulse-dot yellow';
      text.textContent = 'Awaiting QR scan';
      heroWord.textContent = 'waiting';
      heroWord.className = 'text-yellow-400';
    } else {
      badge.classList.add('unhealthy');
      dot.className = 'pulse-dot red';
      text.textContent = 'Offline';
      heroWord.textContent = 'offline';
      heroWord.className = 'text-red-400';
    }
  }

  function tick() {
    fetch('/health')
      .then(r => r.json())
      .then(d => {
        if (!d.qrScanned) {
          window.location.href = '/qr';
          return;
        }

        $('val-status').textContent    = d.status   || '—';
        $('val-qr').textContent        = d.qrScanned ? 'Yes ✓' : 'No';
        $('val-contact').textContent   = d.botContact  || '—';
        $('val-pushname').textContent  = d.botPushName || '—';
        $('val-platform').textContent  = d.botPlatform || '—';
        $('val-uptime').textContent    = formatUptime(parseFloat(d.uptime));
        $('val-version').textContent   = d.version  || '—';
        $('last-updated').textContent  = 'Updated ' + new Date().toLocaleTimeString();

        // Uptime bar — cap at 24h for display
        const uptimeSec = parseFloat(d.uptime) || 0;
        const pct = Math.min((uptimeSec / 86400) * 100, 100);
        $('uptime-fill').style.width = pct + '%';

        setStatus(d.status === 'healthy' ? 'healthy' : 'unhealthy');
      })
      .catch(() => setStatus('unhealthy'));
  }

  tick();
  setInterval(tick, 3000);
</script>
</body>
</html>
