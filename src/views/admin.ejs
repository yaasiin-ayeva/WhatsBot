              <label class="text-xs font-semibold text-gray-500 block mb-1" id="recurring-day-label">Day</label>
              <input type="number" id="campaign-recurringDay" class="field" style="max-width:120px;" min="0" max="31">
            </div>
            <div><label class="text-xs font-semibold text-gray-500 block mb-1">Throttle Rate (msg/min)</label><input type="number" id="campaign-throttle" class="field" style="max-width:120px;" min="1" max="600" value="60"></div>
            <div><label class="text-xs font-semibold text-gray-500 block mb-1">Expiry Date (optional)</label><input type="datetime-local" id="campaign-expires" class="field"></div>
            <div><label class="text-xs font-semibold text-gray-500 block mb-1">Exclude Tags (comma-separated)</label><input type="text" id="campaign-exclude-tags" class="field" placeholder="e.g. vip, opted-out"></div>
            <div><label class="text-xs font-semibold text-gray-500 block mb-1">Campaign Notes</label><textarea id="campaign-notes" rows="2" class="field resize-none" placeholder="Internal notes…"></textarea></div>
          </div>
          <div class="space-y-4">
            <div><div class="text-xs font-semibold text-gray-500 mb-2">Preview</div><div class="wa-bg"><div class="wa-bubble" id="wa-preview-2">Your message will appear here…</div></div></div>
