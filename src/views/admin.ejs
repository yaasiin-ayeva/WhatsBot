            <div class="space-y-1 text-xs text-blue-600">
              <p><strong>Gmail:</strong> host=smtp.gmail.com, port=587, secure=off — use an App Password</p>
              <p><strong>Outlook:</strong> host=smtp-mail.outlook.com, port=587, secure=off</p>
              <p><strong>SendGrid:</strong> host=smtp.sendgrid.net, port=587, user=apikey, pass=SG.xxx</p>
              <p><strong>Brevo:</strong> host=smtp-relay.brevo.com, port=587, user=your-email</p>
            </div>
          </div>
        </div>
        <!-- Email Recipients / Integrations -->
        <div>
          <div class="flex items-center justify-between mb-4">
            <div><h3 class="text-base font-semibold text-gray-900">Email Integrations</h3><p class="text-xs text-gray-500 mt-0.5">Send event notifications to email addresses</p></div>
            <button onclick="openIntegrationModal(null,'email')" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700"><i class="fas fa-plus mr-1.5"></i>Add</button>
          </div>
          <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
            <table class="w-full">
              <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                  <th class="px-4 py-3 text-xs font-semibold text-gray-500 text-left">Name</th>
                  <th class="px-4 py-3 text-xs font-semibold text-gray-500 text-left">Recipients</th>
                  <th class="px-4 py-3 text-xs font-semibold text-gray-500 text-left">Events</th>
                  <th class="px-4 py-3 text-xs font-semibold text-gray-500 text-left">Actions</th>
                </tr>
              </thead>
              <tbody id="email-table-body"><tr><td colspan="4" class="text-center py-10 text-gray-400 text-sm"><i class="fas fa-envelope text-3xl mb-3 block opacity-30"></i>No email integrations configured</td></tr></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Auto-Reply panel -->
    <div id="ipanel-autoreply" class="hidden">
      <div class="flex items-center justify-between mb-4">
        <p class="text-sm text-gray-500">Automatically reply to incoming messages based on keyword rules or AI.</p>
        <button onclick="openAutoReplyModal(null)" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700"><i class="fas fa-plus mr-1.5"></i>Add Rule</button>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-100">
            <tr>
              <th class="px-5 py-3 text-xs font-semibold text-gray-500 text-left">Name</th>
              <th class="px-5 py-3 text-xs font-semibold text-gray-500 text-left">Trigger</th>
              <th class="px-5 py-3 text-xs font-semibold text-gray-500 text-left">Match</th>
              <th class="px-5 py-3 text-xs font-semibold text-gray-500 text-left">Response</th>
              <th class="px-5 py-3 text-xs font-semibold text-gray-500 text-left">Cooldown</th>
              <th class="px-5 py-3 text-xs font-semibold text-gray-500 text-left">Enabled</th>
              <th class="px-5 py-3 text-xs font-semibold text-gray-500 text-left">Actions</th>
            </tr>
          </thead>
          <tbody id="autoreply-table-body"><tr><td colspan="7" class="text-center py-12 text-gray-400 text-sm"><i class="fas fa-robot text-3xl mb-3 block opacity-30"></i>No auto-reply rules configured</td></tr></tbody>
        </table>
      </div>
    </div>

    <!-- Inbound API panel -->
    <div id="ipanel-inbound" class="hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Key management card -->
        <div>
          <h3 class="text-base font-semibold text-gray-900 mb-1">API Key</h3>
          <p class="text-sm text-gray-500 mb-4">Allow external systems to send WhatsApp messages programmatically — no login required, just the key.</p>
          <div class="bg-white border border-gray-200 rounded-xl p-5 space-y-4">
            <div>
              <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-2">Your Secret Key</label>
              <div class="flex gap-2">
                <div class="relative flex-1">
                  <input id="inbound-api-key-input" type="password" class="field font-mono text-sm pr-10" readonly placeholder="No key yet — click Rotate to generate">
                  <button onclick="toggleKeyVisibility()" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600" title="Show/hide"><i id="key-eye-icon" class="fas fa-eye text-sm"></i></button>
                </div>
                <button onclick="copyInboundKey()" class="px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 flex-shrink-0" title="Copy to clipboard"><i class="fas fa-copy"></i></button>
              </div>
            </div>
            <button onclick="rotateInboundKey()" class="w-full py-2 bg-indigo-600 text-white rounded-lg text-sm font-semibold hover:bg-indigo-700 flex items-center justify-center gap-2">
              <i class="fas fa-sync-alt"></i> Rotate Key
            </button>
            <p class="text-xs text-amber-600 bg-amber-50 border border-amber-100 rounded-lg px-3 py-2"><i class="fas fa-exclamation-triangle mr-1"></i>Rotating invalidates the current key immediately. Update all integrations using it.</p>
          </div>
        </div>
        <!-- Usage card -->
        <div>
          <h3 class="text-base font-semibold text-gray-900 mb-1">API Reference</h3>
          <p class="text-sm text-gray-500 mb-4">Send a message to any WhatsApp number using a simple HTTP request.</p>
          <div class="bg-gray-900 rounded-xl overflow-hidden">
            <div class="flex items-center justify-between px-4 py-2.5 border-b border-gray-700">
              <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-red-500"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-yellow-500"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-green-500"></span>
              </div>
              <span class="text-xs text-gray-400 font-mono">POST /crm/inbound/send</span>
              <button onclick="copyApiExample()" class="text-xs text-gray-400 hover:text-white"><i class="fas fa-copy"></i></button>
            </div>
            <pre id="inbound-api-example" class="text-green-300 p-4 text-xs leading-relaxed overflow-x-auto">curl -X POST https://your-domain/crm/inbound/send \
  -H "Content-Type: application/json" \
  -H "x-api-key: YOUR_API_KEY" \
  -d '{
    "phoneNumber": "22890123456",
    "message": "Hello from the API!"
  }'</pre>
          </div>
          <div class="mt-3 bg-white border border-gray-200 rounded-xl p-4 space-y-2">
            <p class="text-xs font-semibold text-gray-600">Response</p>
            <pre class="text-xs text-gray-500 font-mono">{"success": true}  // 200 OK
{"error": "..."}   // 4xx on failure</pre>
            <div class="pt-2 space-y-1 text-xs text-gray-500">
              <p><span class="font-mono bg-gray-100 px-1 rounded">x-api-key</span> — header or body field <span class="font-mono bg-gray-100 px-1 rounded">apiKey</span></p>
              <p><span class="font-mono bg-gray-100 px-1 rounded">phoneNumber</span> — digits only, no + or spaces</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Integration Modal -->
  <div id="integration-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center modal-backdrop">
    <div class="modal-box bg-white rounded-2xl shadow-2xl w-full max-w-lg p-7 relative">
      <button onclick="closeIntegrationModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600"><i class="fas fa-times fa-lg"></i></button>
      <h2 id="integration-modal-title" class="text-xl font-bold text-gray-900 mb-5">Add Webhook</h2>
      <div class="space-y-4">
        <div>
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">Name</label>
          <input id="int-name" class="field" placeholder="e.g. My Webhook">
        </div>
        <div>
          <label id="int-url-label" class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">URL</label>
          <input id="int-url" class="field" placeholder="https://hooks.example.com/…">
          <p id="int-url-hint" class="text-xs text-gray-400 mt-1 hidden">Comma-separated recipient email addresses</p>
        </div>
        <div id="int-secret-wrap">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">Secret (optional, for signature verification)</label>
          <input id="int-secret" class="field font-mono" placeholder="leave blank to skip">
        </div>
        <div>
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-2">Events to subscribe</label>
          <div id="int-events-list" class="grid grid-cols-2 gap-2"></div>
        </div>
        <div class="flex items-center gap-3">
          <div class="toggle-track" id="int-enabled-toggle" onclick="toggleIntEnabled()" title="Enabled"></div>
          <span class="text-sm text-gray-600">Enabled</span>
        </div>
      </div>
      <div class="flex justify-end gap-3 mt-6">
        <button onclick="closeIntegrationModal()" class="px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50">Cancel</button>
        <button onclick="saveIntegration()" class="px-5 py-2 bg-indigo-600 text-white rounded-lg text-sm font-semibold hover:bg-indigo-700">Save</button>
      </div>
    </div>
  </div>

  <!-- Auto-Reply Modal -->
  <div id="autoreply-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center modal-backdrop">
    <div class="modal-box bg-white rounded-2xl shadow-2xl w-full max-w-lg p-7 relative overflow-y-auto" style="max-height:90vh;">
      <button onclick="closeAutoReplyModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600"><i class="fas fa-times fa-lg"></i></button>
      <h2 id="autoreply-modal-title" class="text-xl font-bold text-gray-900 mb-5">Add Auto-Reply Rule</h2>
      <div class="space-y-4">
        <div>
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">Rule Name</label>
          <input id="ar-name" class="field" placeholder="e.g. Greeting Reply">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">Match Type</label>
            <select id="ar-matchtype" class="field">
              <option value="contains">Contains</option>
              <option value="exact">Exact</option>
              <option value="startsWith">Starts With</option>
              <option value="regex">Regex</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">Priority</label>
            <input id="ar-priority" type="number" class="field" value="0" min="0">
          </div>
        </div>
        <div>
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">Trigger Keyword / Pattern</label>
          <input id="ar-trigger" class="field font-mono" placeholder="hello">
        </div>
        <div class="flex items-center gap-3">
          <input type="checkbox" id="ar-useai" onchange="toggleArAI()" class="w-4 h-4 accent-indigo-600">
          <label for="ar-useai" class="text-sm text-gray-700 font-medium">Use AI to generate response</label>
        </div>
        <div id="ar-static-wrap">
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">Static Response</label>
          <textarea id="ar-response" class="field" rows="3" placeholder="Hi! Thanks for reaching out. How can I help you?"></textarea>
        </div>
        <div id="ar-ai-wrap" class="hidden space-y-3">
          <div>
            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">AI Provider</label>
            <select id="ar-aiprovider" class="field">
              <option value="gemini">Gemini (Google)</option>
              <option value="openai">OpenAI (GPT)</option>
              <option value="claude">Claude (Anthropic)</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">System Prompt</label>
            <textarea id="ar-aiprompt" class="field" rows="3" placeholder="You are a helpful WhatsApp assistant. Reply briefly and helpfully."></textarea>
          </div>
        </div>
        <div>
          <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">Cooldown per contact (minutes)</label>
          <input id="ar-cooldown" type="number" class="field" value="60" min="0">
        </div>
        <div class="flex items-center gap-3">
          <div class="toggle-track on" id="ar-enabled-toggle" onclick="toggleArEnabled()" title="Enabled"></div>
          <span class="text-sm text-gray-600">Enabled</span>
        </div>
      </div>
      <div class="flex justify-end gap-3 mt-6">
        <button onclick="closeAutoReplyModal()" class="px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50">Cancel</button>
        <button onclick="saveAutoReply()" class="px-5 py-2 bg-indigo-600 text-white rounded-lg text-sm font-semibold hover:bg-indigo-700">Save</button>
      </div>
    </div>
  </div>

  <!-- Settings -->
  <div id="settings-section" class="section-content hidden p-6">
    <div class="mb-6"><h1 class="text-2xl font-bold text-gray-900">Settings</h1><p class="text-sm text-gray-500 mt-0.5">Bot configuration and runtime paths</p></div>
    <form id="settings-form" class="space-y-5">
      <div class="bg-white border border-gray-200 rounded-2xl p-5">
        <div class="text-sm font-semibold text-gray-800 mb-4">Bot Info</div>
        <div class="grid grid-cols-3 gap-4" id="bot-info-grid"></div>
      </div>
      <div class="bg-white border border-gray-200 rounded-2xl p-5">
        <div class="text-sm font-semibold text-gray-800 mb-1">API Key Status</div>
        <div class="text-xs text-gray-500 mb-4">Loaded from environment or restored from backoffice settings at startup</div>
        <div class="grid grid-cols-3 gap-3" id="api-keys-status-grid"></div>
      </div>
      <div class="bg-white border border-gray-200 rounded-2xl p-5">
        <div class="text-sm font-semibold text-gray-800 mb-1">Update Keys & Local Voice Runtime</div>
        <div class="text-xs text-gray-500 mb-4">Stored securely and applied at runtime. Leave blank to keep current value.</div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="text-xs font-semibold text-gray-500 block mb-1"><span class="inline-flex items-center gap-1"><a href="https://aistudio.google.com/app/apikey" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-indigo-600" title="Open Google AI Studio"><i class="fas fa-info-circle"></i></a><span>GEMINI_API_KEY</span></span></label><input class="field" type="password" id="key-GEMINI_API_KEY" placeholder="Enter new value…" autocomplete="new-password"></div>
          <div><label class="text-xs font-semibold text-gray-500 block mb-1"><span class="inline-flex items-center gap-1"><a href="https://platform.openai.com/api-keys" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-indigo-600" title="Open OpenAI API keys"><i class="fas fa-info-circle"></i></a><span>CHAT_GPT_API_KEY</span></span></label><input class="field" type="password" id="key-CHAT_GPT_API_KEY" placeholder="Enter new value…" autocomplete="new-password"></div>
          <div><label class="text-xs font-semibold text-gray-500 block mb-1"><span class="inline-flex items-center gap-1"><a href="https://console.anthropic.com/" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-indigo-600" title="Open Anthropic Console"><i class="fas fa-info-circle"></i></a><span>ANTHROPIC_API_KEY</span></span></label><input class="field" type="password" id="key-ANTHROPIC_API_KEY" placeholder="Enter new value…" autocomplete="new-password"></div>
          <div><label class="text-xs font-semibold text-gray-500 block mb-1"><span class="inline-flex items-center gap-1"><a href="https://www.weatherapi.com/my/" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-indigo-600" title="Open WeatherAPI dashboard"><i class="fas fa-info-circle"></i></a><span>OPENWEATHERMAP_API_KEY</span></span></label><input class="field" type="password" id="key-OPENWEATHERMAP_API_KEY" placeholder="Enter new value…" autocomplete="new-password"></div>
          <div><label class="text-xs font-semibold text-gray-500 block mb-1">SHERPA_ONNX_ASR_ENCODER_PATH</label><input class="field" type="text" id="key-SHERPA_ONNX_ASR_ENCODER_PATH" placeholder="/opt/sherpa/asr/encoder.onnx" autocomplete="off"></div>
          <div><label class="text-xs font-semibold text-gray-500 block mb-1">SHERPA_ONNX_ASR_DECODER_PATH</label><input class="field" type="text" id="key-SHERPA_ONNX_ASR_DECODER_PATH" placeholder="/opt/sherpa/asr/decoder.onnx" autocomplete="off"></div>
          <div><label class="text-xs font-semibold text-gray-500 block mb-1">SHERPA_ONNX_ASR_TOKENS_PATH</label><input class="field" type="text" id="key-SHERPA_ONNX_ASR_TOKENS_PATH" placeholder="/opt/sherpa/asr/tokens.txt" autocomplete="off"></div>
          <div><label class="text-xs font-semibold text-gray-500 block mb-1">SHERPA_ONNX_TTS_MODEL_PATH</label><input class="field" type="text" id="key-SHERPA_ONNX_TTS_MODEL_PATH" placeholder="/opt/sherpa/tts/model.onnx" autocomplete="off"></div>
          <div><label class="text-xs font-semibold text-gray-500 block mb-1">SHERPA_ONNX_TTS_TOKENS_PATH</label><input class="field" type="text" id="key-SHERPA_ONNX_TTS_TOKENS_PATH" placeholder="/opt/sherpa/tts/tokens.txt" autocomplete="off"></div>
          <div><label class="text-xs font-semibold text-gray-500 block mb-1">SHERPA_ONNX_TTS_LEXICON_PATH</label><input class="field" type="text" id="key-SHERPA_ONNX_TTS_LEXICON_PATH" placeholder="/opt/sherpa/tts/lexicon.txt (optional)" autocomplete="off"></div>
        </div>
      </div>
      <div class="bg-white border border-gray-200 rounded-2xl p-5">
        <div class="text-sm font-semibold text-gray-800 mb-4">Download Settings</div>
        <div class="flex items-center gap-8">
          <div><label class="text-xs font-semibold text-gray-500 block mb-1">Max File Size (MB)</label><input type="number" id="setting-maxFileSizeMb" class="field" style="max-width:140px;" min="1" max="2000"></div>
          <div><label class="text-xs font-semibold text-gray-500 block mb-1">Voice AI Provider</label><select id="setting-defaultAudioAiCommand" class="field" style="min-width:220px;"><option value="chat">Gemini</option><option value="gpt">OpenAI GPT</option><option value="claude">Claude</option></select></div>
          <div class="flex items-center gap-3 mt-4">
            <div class="toggle-track" id="toggle-autoDownload" onclick="toggleAutoDownload()"><div class="toggle-thumb"></div></div>
            <div><div class="text-sm font-medium text-gray-800">Auto-download</div><div class="text-xs text-gray-500">Automatically download media from URLs</div></div>
          </div>
        </div>
      </div>
      <div class="flex justify-end">
        <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-xl text-sm font-semibold transition-colors">Save Settings</button>
      </div>
    </form>
  </div>

</main>

<!-- MODALS -->

<!-- Campaign Modal -->
<div id="campaign-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4">
  <div class="modal-backdrop absolute inset-0" onclick="closeCampaignModal()"></div>
  <div class="modal-box relative bg-white rounded-2xl shadow-2xl w-full overflow-hidden" style="max-width:960px;max-height:92vh;display:flex;flex-direction:column;">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 flex-shrink-0">
      <h2 id="campaign-modal-title" class="text-lg font-bold text-gray-900">New Campaign</h2>
      <button onclick="closeCampaignModal()" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg"><i class="fas fa-times"></i></button>
    </div>
    <div class="flex border-b border-gray-100 flex-shrink-0">
      <div class="ctab active" id="ctab-compose" onclick="switchCampaignTab('compose')"><i class="fas fa-pen-to-square mr-1.5 text-xs"></i>Compose</div>
      <div class="ctab" id="ctab-recipients" onclick="switchCampaignTab('recipients')"><i class="fas fa-users mr-1.5 text-xs"></i>Recipients</div>
      <div class="ctab" id="ctab-schedule" onclick="switchCampaignTab('schedule')"><i class="fas fa-clock mr-1.5 text-xs"></i>Schedule &amp; Send</div>
    </div>
    <div class="overflow-y-auto flex-grow">
      <div id="ctab-compose-content" class="p-6">
        <div class="grid gap-5" style="grid-template-columns:1fr 1fr;">
          <div class="space-y-4">
            <div><label class="text-xs font-semibold text-gray-500 block mb-1">Campaign Name *</label><input id="campaign-name" class="field" placeholder="e.g. Weekly Promo" oninput="updateWaPreview();updateScheduleSummary()"></div>
            <div>
              <div class="flex items-center justify-between mb-1"><label class="text-xs font-semibold text-gray-500">Message *</label><span class="text-xs text-gray-400" id="msg-char-count">0 chars</span></div>
              <div class="flex gap-1.5 mb-2 flex-wrap">
                <button type="button" onclick="insertVariable('{{name}}')" class="text-xs bg-indigo-50 hover:bg-indigo-100 text-indigo-700 px-2.5 py-1 rounded-lg font-semibold">{{name}}</button>
                <button type="button" onclick="insertVariable('{{phone}}')" class="text-xs bg-indigo-50 hover:bg-indigo-100 text-indigo-700 px-2.5 py-1 rounded-lg font-semibold">{{phone}}</button>
                <button type="button" onclick="insertVariable('{{date}}')" class="text-xs bg-indigo-50 hover:bg-indigo-100 text-indigo-700 px-2.5 py-1 rounded-lg font-semibold">{{date}}</button>
              </div>
              <textarea id="campaign-message" rows="7" class="field resize-none" placeholder="Write your message…" oninput="updateWaPreview()"></textarea>
            </div>
            <div><label class="text-xs font-semibold text-gray-500 block mb-1">Use Template</label><select id="template-selector" onchange="applyTemplateToModal()" class="field"><option value="">— Select a template —</option></select></div>
            <div>
              <label class="text-xs font-semibold text-gray-500 block mb-1">Media Attachment (optional)</label>
              <div class="flex gap-2 items-center">
                <input id="campaign-media-url" class="field text-xs" placeholder="Paste image / video URL…" oninput="updateMediaPreview()">
                <button type="button" onclick="document.getElementById('campaign-media-url').value='';updateMediaPreview()" class="text-gray-400 hover:text-red-500 flex-shrink-0" title="Clear"><i class="fas fa-times"></i></button>
              </div>
              <div id="media-preview-wrap" class="hidden mt-2"><img id="media-preview-img" src="" alt="preview" class="max-h-24 rounded-lg border border-gray-200 object-contain"></div>
              <p class="text-xs text-gray-400 mt-1">Supported: image (jpg/png/gif/webp), video (mp4), document (pdf). Must be a direct public URL.</p>
            </div>
          </div>
          <div><div class="text-xs font-semibold text-gray-500 mb-2">Preview</div><div class="wa-bg"><div class="wa-bubble" id="wa-preview">Your message will appear here…</div></div></div>
        </div>
      </div>
      <div id="ctab-recipients-content" class="p-6 hidden">
